{
  "version": 2,
  "name": "datamapper-ai",
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "env": {
    "DM_API_URL": "https://datamapper-ai-api.onrender.com"
  }
}
