# xREF DataMapper — environment configuration
# ─────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys below
# 3. Never commit .env — it is git-ignored

# ── LLM Provider (pick one) ───────────────────────────────────────────────────

# Option A — Anthropic Claude (default)
DM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-api03-...
DM_CLAUDE_MODEL=claude-sonnet-4-6   # optional override

# Option B — DeepSeek (cheaper, fast)
# DM_PROVIDER=deepseek
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Option C — Any OpenAI-compatible endpoint
# DM_PROVIDER=custom
# LLM_API_KEY=your_key
# LLM_BASE_URL=https://your-endpoint/v1
# LLM_MODEL=your-model-name

# ── BigQuery target connector (optional) ──────────────────────────────────────
# BQ_PROJECT_ID=your-gcp-project
# BQ_DATASET=your_dataset
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Jira integration (optional) ───────────────────────────────────────────────
# JIRA_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=you@yourorg.com
# JIRA_TOKEN=your_jira_api_token

# ── Slack notifications (optional) ────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Auth (change before any team or production deployment) ────────────────────
XREF_SECRET_KEY=xref-change-this-secret-before-deploy
XREF_ADMIN_EMAIL=admin@yourcompany.com
XREF_ADMIN_PASSWORD=change-me

# ── Server tuning (optional — defaults shown) ─────────────────────────────────
# DM_ENV=production
# DM_ALLOWED_ORIGINS=https://your-domain.com
# DM_RATE_LIMIT=60
# DM_MAX_UPLOAD_MB=20
